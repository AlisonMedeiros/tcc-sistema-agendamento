# Copie para .env e preencha com os dados do seu PostgreSQL
PORT=3000

DB_USER=postgres
DB_PASSWORD=sua_senha
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agendamento_debora

# Chave secreta para assinar os tokens JWT (use uma string longa e aleatória!)
JWT_SECRET=troque_por_uma_chave_aleatoria_longa

# Configurações do Servidor de E-mail (SMTP)
# Para o Gmail, SMTP_HOST é smtp.gmail.com e SMTP_PORT é 465 (seguro) ou 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seu_email_aqui@gmail.com
SMTP_PASS=sua_senha_de_aplicativo_aqui
FRONTEND_URL=http://localhost:3000
