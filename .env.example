PORT=3000

# Dados do Banco de Dados PostgreSQL (Supabase ou Local)
DB_USER=postgres
DB_PASSWORD=sua_senha_do_banco_aqui
DB_HOST=localhost_ou_host_do_supabase
DB_PORT=5432
DB_NAME=nome_do_seu_banco

# Chave secreta para assinar os tokens JWT (use uma string longa e aleatória!)
JWT_SECRET=troque_por_uma_chave_aleatoria_longa

# URL correta para o sistema em produção (sem barra no final)
FRONTEND_URL=https://gundem.com.br

# Chave do Resend para envio de e-mails via API (Porta 443)
RESEND_API_KEY=re_sua_chave_da_api_do_resend_aqui